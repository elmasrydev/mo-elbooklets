{
  "expo": {
    "name": "El Booklets",
    "locales": {
      "en": "./locales/en.json",
      "ar": "./locales/ar.json"
    },
    "slug": "mobile-elbooklets",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F3F5FB"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.elbooklets.app",
      "buildNumber": "70",
      "appleTeamId": "XJAN9FLEYZ",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.elbooklets.app",
      "versionCode": 8,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3F5FB"
      },
      "supportsRtl": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/adaptive-icon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/d4dcdf3d-7581-496d-96a9-c5acca79629d",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.1",
    "plugins": [
      "expo-font",
      "./plugins/withAndroidSigning.js",
      "./plugins/withIosModularHeaders.js",
      "./plugins/withAndroidExtraStrings.js",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "@react-native-firebase/messaging",
      "./plugins/withIosPushNotifications.js",
      "./plugins/withAndroidNotificationIcon.js"
    ],
    "extra": {
      "debugMode": true,
      "eas": {
        "projectId": "d4dcdf3d-7581-496d-96a9-c5acca79629d"
      }
    }
  }
}
