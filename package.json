{
  "name": "mobile-elbooklets",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "codegen": "graphql-codegen --config codegen.yml",
    "codegen:watch": "graphql-codegen --config codegen.yml --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "build:apk": "npx expo prebuild --platform android --clean && cd android && ./gradlew assembleRelease",
    "build:aab": "npx expo prebuild --platform android --clean && cd android && ./gradlew bundleRelease",
    "iosnuke": "watchman watch-del-all && rm -rf node_modules ios && yarn install && npx expo prebuild --platform ios --clean && npx expo run:ios",
    "androidnuke": "watchman watch-del-all && rm -rf node_modules android && yarn install && npx expo prebuild --platform android --clean && npx expo run:android",
    "test:prs": "cross-env APP_ENV=prs jest",
    "test:dev": "cross-env APP_ENV=dev jest",
    "test:prod": "cross-env APP_ENV=prod jest",
    "e2e:prs": "python3 scripts/run_maestro.py prs",
    "e2e:dev": "python3 scripts/run_maestro.py dev",
    "e2e:prod": "python3 scripts/run_maestro.py prod",
    "guardme:clean-code": "npm run lint && npx tsc --noEmit",
    "guardme:docs": "python3 scripts/verify_docs.py",
    "guardme:prs": "npm run guardme:clean-code && npm run test:prs && npm run guardme:docs",
    "guardme:dev": "npm run guardme:clean-code && npm run test:dev && npm run guardme:docs",
    "guardme:prod": "npm run guardme:clean-code && npm run test:prod && npm run guardme:docs"
  },
  "dependencies": {
    "@apollo/client": "^4.0.7",
    "@expo-google-fonts/lexend": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/crashlytics": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-firebase/remote-config": "^23.8.6",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.8",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.10.0",
    "@react-navigation/stack": "^7.4.9",
    "@segment/analytics-react-native": "^2.22.0",
    "@segment/analytics-react-native-plugin-firebase": "^1.0.0",
    "@segment/sovran-react-native": "^1.1.3",
    "date-fns": "^4.1.0",
    "expo": "~54.0.12",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "^55.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "~29.0.12",
    "graphql": "^16.11.0",
    "i18next": "^25.7.3",
    "intl-pluralrules": "^2.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.1",
    "react-native": "0.81.5",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "~0.6.0",
    "react-native-worklets-core": "^1.6.3",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "reactotron-react-native": "^5.1.18",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react-native-get-random-values": "$react-native-get-random-values"
  },
  "private": true
}